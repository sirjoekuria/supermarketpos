{
  "name": "supermarket-pos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:capacitor": "cross-env CAPACITOR_BUILD=true next build",
    "start": "next start",
    "lint": "next lint",
    "cap:sync": "npm run build:capacitor && npx cap sync android",
    "cap:dev": "npm run build:capacitor && npx cap open android",
    "cap:update": "npx cap sync android",
    "cap:copy": "npx cap copy android",
    "cap:run": "npm run build:capacitor && npx cap run android --external",
    "android:build": "cd android && .\\gradlew.bat assembleDebug",
    "android:release": "cd android && .\\gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/core": "^5.5.0",
    "@supabase/auth-helpers-nextjs": "^0.8.7",
    "@supabase/supabase-js": "^2.39.0",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.16",
    "date-fns": "^3.0.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.294.0",
    "next": "14.2.0",
    "postcss": "^8.4.32",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.10.3",
    "tailwindcss": "^3.3.6",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^5.5.0",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.5.10",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "14.2.0",
    "tailwind-merge": "^3.6.0",
    "typescript": "^5.3.3"
  }
}
